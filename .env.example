# Camera source. Keep values in an ignored local .env file.
CAMZILLA_CAMERA_NAME=front-door
CAMZILLA_CAMERA_RTSP_URL=rtsp://camera.local:554/stream
# Local internal restream used only by the sampler, not the browser.
CAMZILLA_INFERENCE_RESTREAM_URL=rtsp://go2rtc:8554/front-door

# Services bind to loopback by default. Set 0.0.0.0 only on a trusted LAN.
CAMZILLA_BIND_HOST=127.0.0.1
CAMZILLA_API_PORT=8000
CAMZILLA_FRONTEND_PORT=5173
CAMZILLA_WEBRTC_CANDIDATE=127.0.0.1:8555

# Inference defaults to a deterministic fake backend so development and CI need
# neither a camera nor model weights. Set ultralytics after installing weights.
CAMZILLA_INFERENCE_BACKEND=fake
# Supported detection weights: yolov8n, yolov8s, yolov8m, yolo11n, yolo11s,
# and yolo11m. The default path is /models/<CAMZILLA_MODEL_ID>.pt.
CAMZILLA_MODEL_ID=yolov8n
# CAMZILLA_MODEL_PATH=/models/yolov8n.pt
CAMZILLA_INFERENCE_DEVICE=auto
CAMZILLA_INFERENCE_FPS=5
CAMZILLA_CONFIDENCE_THRESHOLD=0.50
CAMZILLA_ALLOWED_CLASSES=person
CAMZILLA_RESULT_TTL_SECONDS=2.0

# Optional bounded PTZ. Enable only after the listed ONVIF operation has been
# verified on the camera; credentials remain in ignored local configuration.
CAMZILLA_PTZ_ENABLED=false
CAMZILLA_PTZ_VERIFIED=false
CAMZILLA_ONVIF_HOST=camera.local
CAMZILLA_ONVIF_PORT=8000
CAMZILLA_ONVIF_PROFILE=PROFILE_000
CAMZILLA_ONVIF_USER=
CAMZILLA_ONVIF_PASSWORD=

# Alert evaluation runs in dry-run mode by default. Real Discord delivery also
# requires a webhook URL and an explicit confirmation flag.
CAMZILLA_ALERTS_ENABLED=true
CAMZILLA_ALERT_CLASSES=person
CAMZILLA_ALERT_CONFIDENCE_THRESHOLD=0.60
CAMZILLA_ALERT_DEBOUNCE_SECONDS=300
CAMZILLA_NOTIFIER=dry-run
CAMZILLA_DISCORD_WEBHOOK_URL=
CAMZILLA_DISCORD_DELIVERY_CONFIRMED=false
